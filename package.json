{
  "name": "peekmd",
  "version": "0.3.0",
  "description": "Beautiful markdown, one link away",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/notacryptodad/peekmd.git"
  },
  "homepage": "https://peekmd.dev",
  "type": "module",
  "bin": {
    "peekmd": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    },
    "./store": {
      "import": "./dist/memory-store.js",
      "types": "./dist/memory-store.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "tsx watch src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@x402/core": "^2.7.0",
    "dompurify": "^3.2.4",
    "fastify": "^5.2.1",
    "highlight.js": "^11.11.1",
    "jsdom": "^26.0.0",
    "marked": "^15.0.6",
    "nanoid": "^5.1.2",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "@types/dompurify": "^3.2.0",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^22.12.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
